# Intelligence Pipeline - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# Backend Configuration
# ============================================================================

# Server
PORT=8000

# Database
SQLITE_DB=./data/websets.db

# Redis (Message Broker & Cache)
REDIS_URL=redis://redis:6379/0

# RuVector (Vector Database)
RUVECTOR_DATA_DIR=./data/ruvector

# ============================================================================
# LLM API Configuration
# ============================================================================

# Requesty Router (Recommended - Multi-provider LLM router)
REQUESTY_BASE_URL=https://router.requesty.ai/v1
REQUESTY_API_KEY=your_requesty_api_key_here
REQUESTY_DEFAULT_MODEL=google/gemini-2.5-flash

# OpenAI (Alternative)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Anthropic (Alternative)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ============================================================================
# Security Configuration
# ============================================================================

# JWT Secret (Generate with: openssl rand -hex 32)
JWT_SECRET_KEY=your_secret_key_here

# API Keys for authentication (comma-separated)
API_KEYS=key1,key2,key3

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================================================
# Celery Configuration
# ============================================================================

# Celery Broker & Backend
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Worker Concurrency
CELERY_REALTIME_CONCURRENCY=4
CELERY_BATCH_CONCURRENCY=2
CELERY_BACKGROUND_CONCURRENCY=1

# Task Result Expiration (seconds)
CELERY_RESULT_EXPIRES=3600

# ============================================================================
# Monitoring & Logging
# ============================================================================

# Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log Directory
LOG_DIR=./logs

# Enable Flower Monitoring UI
FLOWER_ENABLED=true
FLOWER_PORT=5555

# ============================================================================
# Web Scraping Configuration
# ============================================================================

# Playwright Browser Settings
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000

# User Agent
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# Request Timeout (seconds)
REQUEST_TIMEOUT=30

# Max Retries
MAX_RETRIES=3

# ============================================================================
# Content Processing
# ============================================================================

# Maximum content size (bytes)
MAX_CONTENT_SIZE=10485760

# Chunk Size for batch processing
BATCH_CHUNK_SIZE=100

# Enable content caching
ENABLE_CACHING=true

# Cache TTL (seconds)
CACHE_TTL=86400

# ============================================================================
# Vector Database Settings
# ============================================================================

# Embedding Model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Vector Dimension
VECTOR_DIMENSION=384

# HNSW Parameters
HNSW_M=16
HNSW_EF_CONSTRUCTION=200
HNSW_EF_SEARCH=50

# ============================================================================
# Rate Limiting
# ============================================================================

# Requests per minute
RATE_LIMIT_PER_MINUTE=60

# Burst limit
RATE_LIMIT_BURST=10

# ============================================================================
# Feature Flags
# ============================================================================

# Enable/disable features
ENABLE_ENRICHMENTS=true
ENABLE_MONITORING=true
ENABLE_WEBSETS=true
ENABLE_PREPROCESSING=true

# ============================================================================
# Development Settings
# ============================================================================

# Environment (development, staging, production)
ENVIRONMENT=development

# Debug mode
DEBUG=false

# Reload on code changes (development only)
RELOAD=true

# ============================================================================
# Production Settings
# ============================================================================

# Number of Uvicorn workers (production)
WORKERS=4

# Database connection pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ============================================================================
# Frontend Configuration
# ============================================================================

# API URL for frontend
VITE_API_URL=http://localhost:8000
