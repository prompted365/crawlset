FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y \
    curl \
    && rm -rf /var/lib/apt/lists/*

COPY requirements/ ./requirements/
RUN pip install --no-cache-dir -r requirements/flower.txt

# Flower does not import the celery app — it connects via broker URL directly.
# This keeps all app source (and its transitive deps) out of the flower image.
CMD ["sh", "-c", "celery --broker=${REDIS_URL} --result-backend=${REDIS_URL} flower --port=5555"]
